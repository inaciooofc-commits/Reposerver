# .env.example - Renomeie para .env e preencha com seus valores

# Ambiente da Aplicação: 'development' ou 'production'
FLASK_ENV=development

# Configuração do Servidor Web
HOST=0.0.0.0
PORT=5000

# Chave Secreta: Use uma string longa, aleatória e complexa para segurança.
# Gere uma com: python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY='your_super_secret_and_long_random_string_here'

# Nível de Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Configuração do Banco de Dados (SQLite por padrão)
DATABASE_URL='sqlite:///../instance/reposerver.db'
